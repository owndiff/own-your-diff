{
  "max_scan_bytes": 5242880,
  "forbidden_staged_paths": [
    ".owndiff/**",
    ".research/**",
    ".owndiff-test-repos/**",
    ".venv/**",
    ".venv*/**",
    ".pytest_cache/**",
    ".ruff_cache/**",
    ".codex/**",
    ".claude/**",
    ".cursor/**",
    ".gemini/**",
    "**/__pycache__/**",
    "**/.env",
    "**/.env.*",
    "*.pem",
    "*.key",
    "*.p12",
    "*.pfx",
    ".idea/**",
    "*.log",
    "*.tmp",
    ".DS_Store"
  ],
  "privacy_patterns": [
    {
      "id": "mac_home_path",
      "pattern": "/Users/[A-Za-z0-9._-]+/"
    },
    {
      "id": "linux_home_path",
      "pattern": "/home/[A-Za-z0-9._-]+/"
    },
    {
      "id": "windows_home_path",
      "pattern": "(?i)C:\\\\Users\\\\[A-Za-z0-9._-]+\\\\"
    },
    {
      "id": "private_key",
      "pattern": "-----BEGIN [A-Z ]*PRIVATE KEY-----"
    },
    {
      "id": "aws_access_key",
      "pattern": "(AKIA|ASIA)[0-9A-Z]{16}"
    },
    {
      "id": "github_token",
      "pattern": "(gh[pousr]_[A-Za-z0-9_]{20,}|github_pat_[A-Za-z0-9_]+)"
    },
    {
      "id": "openai_api_key",
      "pattern": "sk-[A-Za-z0-9]{20,}"
    },
    {
      "id": "anthropic_api_key",
      "pattern": "sk-ant-[A-Za-z0-9_-]{20,}"
    },
    {
      "id": "google_api_key",
      "pattern": "AIza[0-9A-Za-z_-]{35}"
    },
    {
      "id": "slack_token",
      "pattern": "xox[baprs]-[A-Za-z0-9-]{10,}"
    },
    {
      "id": "bearer_token",
      "pattern": "(?i)Authorization\\s*:\\s*Bearer\\s+[A-Za-z0-9._-]{20,}"
    },
    {
      "id": "jwt",
      "pattern": "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}"
    },
    {
      "id": "api_secret",
      "pattern": "(?i)(api[_-]?key|secret|password|token)\\s*[:=]\\s*[\"']?[A-Za-z0-9_./+=-]{20,}"
    }
  ],
  "privacy_review_patterns": [
    {
      "id": "redaction_marker",
      "pattern": "(?i)\\b(redacted|redact me|secret removed)\\b"
    }
  ],
  "privacy_allowlist": [
    {
      "id": "api_secret",
      "paths": [
        "tests/test_owndiff.py"
      ],
      "pattern": "(not-a-real-[A-Za-z0-9-]+|x{20,}|abcdefghijklmnopqrstuvwxyz)"
    }
  ],
  "required_files": [
    "README.md",
    "SKILL.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE",
    "skills.sh.json",
    ".claude-plugin/plugin.json",
    ".codex-plugin/plugin.json",
    "configs/default_config.yaml",
    "scripts/verify_release_assets.py"
  ],
  "release_integrity": {
    "expected_assets": [
      "owndiff-darwin-arm64",
      "owndiff-darwin-x86_64",
      "owndiff-linux-arm64",
      "owndiff-linux-x86_64"
    ],
    "installer_path": "install.sh",
    "ci_workflow_path": ".github/workflows/ci.yml",
    "release_workflow_path": ".github/workflows/release-binaries.yml",
    "linux_build_script_path": "scripts/build_linux_release_binary.sh",
    "verifier_path": "scripts/verify_release_assets.py",
    "forbidden_installer_term_parts": [
      ["OWNDIFF_", "DOWNLOAD_URL"],
      ["OWNDIFF_", "CHECKSUM_URL"],
      ["OWNDIFF_", "REPO"]
    ]
  },
  "version_sources": [
    {
      "path": "pyproject.toml",
      "pattern": "(?m)^version\\s*=\\s*\"([^\"]+)\""
    },
    {
      "path": "uv.lock",
      "pattern": "(?ms)\\[\\[package\\]\\]\\s*name\\s*=\\s*\"owndiff\"\\s*version\\s*=\\s*\"([^\"]+)\""
    },
    {
      "path": "scripts/owndifflib/__init__.py",
      "pattern": "__version__\\s*=\\s*\"([^\"]+)\""
    },
    {
      "path": ".claude-plugin/plugin.json",
      "pattern": "\"version\"\\s*:\\s*\"([^\"]+)\""
    },
    {
      "path": ".codex-plugin/plugin.json",
      "pattern": "\"version\"\\s*:\\s*\"([^\"]+)\""
    }
  ],
  "checks": [
    {
      "name": "ruff",
      "command": [
        "{python}",
        "-m",
        "ruff",
        "check",
        "."
      ],
      "timeout_seconds": 120
    },
    {
      "name": "pytest",
      "command": [
        "{python}",
        "-m",
        "pytest",
        "-q"
      ],
      "timeout_seconds": 180
    },
    {
      "name": "diff-check",
      "command": [
        "git",
        "diff",
        "--cached",
        "--check"
      ],
      "timeout_seconds": 30
    }
  ]
}
